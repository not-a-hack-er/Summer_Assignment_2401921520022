  459. Repeated Substring Pattern



  class Solution {
public:
    bool repeatedSubstringPattern(string s) {
    int n = s.size();

    for(int len=1; len<=n/2; len++) {
        if(n % len != 0) continue;

        string pattern = s.substr(0, len);
        string temp = "";

        while(temp.size() < n)
            temp += pattern;

        if(temp == s)
            return true;
    }

    return false;
}
};
